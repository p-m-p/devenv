export EDITOR="nvim"
export NVM_AUTO_USE=true
export COLORTERM="truecolor"
export PATH="$HOME/.local/bin:$PATH"

alias docker="podman"
alias mux="tmuxinator"
alias pc="podman-compose"

# Only alias if commands exist (bat is batcat on Ubuntu, symlinked to ~/.local/bin/bat)
command -v bat &> /dev/null && alias cat="bat"
command -v eza &> /dev/null && alias ls="eza" && alias ll="eza -la" && alias tree="eza --tree"

# Platform-specific setup
if command -v brew &> /dev/null; then
  export HOMEBREW_BUNDLE_FILE="$HOME/Brewfile"
  export ZPLUG_HOME=$(brew --prefix zplug)
else
  export ZPLUG_HOME="$HOME/.zplug"
  export PATH="$HOME/.local/share/bob/nvim-bin:$HOME/.cargo/bin:$HOME/go/bin:$PATH"
fi

source $ZPLUG_HOME/init.zsh

zplug "zsh-users/zsh-history-substring-search"
zplug "zsh-users/zsh-autosuggestions"
zplug "zsh-users/zsh-syntax-highlighting", defer:2
zplug "catppuccin/zsh-syntax-highlighting", use:themes/catppuccin_mocha-zsh-syntax-highlighting.zsh
zplug "jeffreytse/zsh-vi-mode"
zplug "mafredri/zsh-async"
zplug "sindresorhus/pure", use:pure.zsh, as:theme
zplug "p-m-p/pure-catppuccin", use:style/mocha.zsh, from:github, at:main
zplug "lukechilds/zsh-nvm"

if ! zplug check --verbose; then
    printf "Install? [y/N]: "
    if read -q; then
        echo; zplug install
    fi
fi

zplug load

bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

# pnpm
if [[ "$OSTYPE" == "darwin"* ]]; then
  export PNPM_HOME="$HOME/Library/pnpm"
else
  export PNPM_HOME="$HOME/.local/share/pnpm"
fi
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# 1Password CLI plugins (macOS)
[ -f "$HOME/.config/op/plugins.sh" ] && source "$HOME/.config/op/plugins.sh"

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

command -v direnv &> /dev/null && eval "$(direnv hook zsh)"
command -v zoxide &> /dev/null && eval "$(zoxide init zsh --cmd cd)"
