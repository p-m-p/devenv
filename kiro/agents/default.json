{
  "name": "default",
  "description": "Default agent with all tools allowed",
  "tools": ["*"],
  "allowedTools": [
    "read",
    "write",
    "shell",
    "grep",
    "glob",
    "aws",
    "@*"
  ],
  "toolsSettings": {
    "shell": {
      "autoAllowReadonly": true
    },
    "subagent": {
      "availableAgents": ["*"],
      "trustedAgents": ["*"]
    }
  }
}
